{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "resolveJsonModule": true,  // <--- ADD THIS
    "esModuleInterop": true ,    // <--- ADD THIS
    "paths": {
      "@/*": [
